generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("Data Collector")
  consents     Consent[]
  createdAt    DateTime  @default(now())
}

model Consent {
  id                       String   @id @default(cuid())
  referenceNumber          String   @unique
  participantName          String
  participantPhone         String?
  programName              String   @default("10X: Enabling growth of MSMEs through the digital economy")
  consentFormType          String   @default("sample-space")
  implementingOrganization String?
  dataCollectorOrganization String?
  dataCollectorContact     String?
  privacyOrganization      String?
  privacyPolicyUrl         String?
  withdrawalContact        String?
  dataSharingOrganization  String?
  consentDecision          String
  serviceRequired          String?
  authorizedPartners       String[] @default([])
  dataShared               String[] @default([])
  informationUnderstood    Boolean  @default(false)
  signingMethod            String
  signatureFile            String
  signatureFileKey         String
  interpreterUsed          Boolean  @default(false)
  interpreterName          String?
  interpreterOrganization  String?
  interpreterLanguage      String?
  interpreterSignatureFile String?
  interpreterSignatureFileKey String?
  collectorName            String?
  collectorId              String?
  collector                User?    @relation(fields: [collectorId], references: [id])
  consentDate              DateTime
  consentFormVersion       String   @default("10X-SAMPLE-v1")
  pdfFile                  String?
  pdfFileKey               String?
  pdfGeneratedAt           DateTime?
  status                   String   @default("locked")
  createdAt                DateTime @default(now())
}
