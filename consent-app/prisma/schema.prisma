generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("Data Collector")
  consents     Consent[]
  createdAt    DateTime  @default(now())
}

model Consent {
  id                       String   @id @default(cuid())
  referenceNumber          String   @unique
  participantId            String?
  participant              Participant? @relation(fields: [participantId], references: [id])
  esoId                    String?
  eso                      Eso?     @relation(fields: [esoId], references: [id])
  participantName          String
  participantPhone         String?
  participantExternalId    String?
  programName              String   @default("10X: Enabling growth of MSMEs through the digital economy")
  esoName                  String?
  consentFormType          String   @default("sample-space")
  implementingOrganization String?
  dataCollectorOrganization String?
  dataCollectorContact     String?
  privacyOrganization      String?
  privacyPolicyUrl         String?
  withdrawalContact        String?
  dataSharingOrganization  String?
  consentDecision          String
  serviceRequired          String?
  authorizedPartners       String[] @default([])
  dataShared               String[] @default([])
  informationUnderstood    Boolean  @default(false)
  signingMethod            String
  signatureFile            String
  signatureFileKey         String
  interpreterUsed          Boolean  @default(false)
  interpreterName          String?
  interpreterOrganization  String?
  interpreterLanguage      String?
  interpreterSignatureFile String?
  interpreterSignatureFileKey String?
  collectorName            String?
  collectorId              String?
  collector                User?    @relation(fields: [collectorId], references: [id])
  consentDate              DateTime
  consentFormVersion       String   @default("10X-SAMPLE-v1")
  pdfFile                  String?
  pdfFileKey               String?
  pdfGeneratedAt           DateTime?
  pdfStatus                String   @default("pending")
  supersededById           String?
  status                   String   @default("locked")
  createdAt                DateTime @default(now())

  @@index([participantId])
  @@index([esoId])
  @@index([consentDecision])
  @@index([status])
  @@index([pdfStatus])
  @@index([createdAt])
}

model Eso {
  id           String        @id @default(cuid())
  name         String        @unique
  code         String?       @unique
  status       String        @default("active")
  participants Participant[]
  consents     Consent[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Participant {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  fullName       String
  normalizedName String
  phone          String?
  email          String?
  esoName        String
  esoCode        String?
  esoId          String?
  eso            Eso?     @relation(fields: [esoId], references: [id])
  consents       Consent[]
  district       String?
  region         String?
  sector         String?
  status         String   @default("active")
  source         String   @default("participant_csv")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([esoName])
  @@index([esoId])
  @@index([normalizedName])
  @@index([status])
}
